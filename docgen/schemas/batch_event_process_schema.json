{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "バッチ・イベント処理スキーマ",
  "description": "夜間バッチや非同期イベント処理など、バックグラウンドで実行される処理を定義するためのスキーマ。",
  "type": "object",
  "properties": {
    "metadata": {
      "$ref": "common_metadata_schema.json"
    },
    "processes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "processId": {
            "type": "string",
            "description": "処理の一意なID（例: BATCH-001, EVT-001）",
            "pattern": "^(BATCH|EVT)-\\d{3}$"
          },
          "processName": {
            "type": "string",
            "description": "処理の名称（例: 日次売上集計バッチ）"
          },
          "description": {
            "type": "string",
            "description": "処理の目的や概要"
          },
          "processType": {
            "type": "string",
            "enum": ["Batch", "EventDriven"],
            "description": "処理のタイプ"
          },
          "trigger": {
            "type": "object",
            "description": "処理が開始されるトリガー",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["Schedule", "Event"],
                "description": "トリガーの種類"
              },
              "schedule": {
                "type": "string",
                "description": "cron形式の実行スケジュール（Scheduleの場合）",
                "pattern": "^(\\*|([0-9]|1[0-9]|2[0-9]|3[0-9]|4[0-9]|5[0-9])|([0-9]|1[0-9]|2[0-3])|([1-9]|1[0-9]|2[0-9]|3[0-1])|([1-9]|1[0-2])|([0-6]))(\\s(\\*|([0-9]|1[0-9]|2[0-9]|3[0-9]|4[0-9]|5[0-9])|([0-9]|1[0-9]|2[0-3])|([1-9]|1[0-9]|2[0-9]|3[0-1])|([1-9]|1[0-2])|([0-6]))){4}$"
              },
              "eventName": {
                "type": "string",
                "description": "トリガーとなるイベント名（Eventの場合）"
              },
              "sourceComponentId": {
                "type": "string",
                "description": "イベントの発行元コンポーネントID"
              }
            },
            "required": ["type"]
          },
          "tasks": {
            "type": "array",
            "description": "実行されるタスクのリスト",
            "items": {
              "type": "object",
              "properties": {
                "taskId": {
                  "type": "string"
                },
                "taskName": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "componentId": {
                  "type": "string",
                  "description": "処理を実行するコンポーネントのID"
                },
                "dependencies": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": ["taskId", "taskName", "componentId"]
            }
          },
          "dataHandling": {
            "type": "object",
            "properties": {
              "inputs": {
                "type": "array",
                "items": { "type": "string", "description": "入力データ（テーブル名、ファイル名など）" }
              },
              "outputs": {
                "type": "array",
                "items": { "type": "string", "description": "出力データ（テーブル名、ファイル名など）" }
              }
            }
          },
          "errorHandling": {
            "type": "object",
            "properties": {
              "retryCount": {
                "type": "integer",
                "default": 0
              },
              "retryIntervalSeconds": {
                "type": "integer"
              },
              "onFailure": {
                "type": "string",
                "description": "失敗時の通知先や処理"
              }
            }
          }
        },
        "required": ["processId", "processName", "processType", "trigger", "tasks"]
      }
    }
  },
  "required": ["metadata", "processes"]
}